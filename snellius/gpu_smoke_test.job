#!/bin/bash
#SBATCH --job-name=mt-gpu-test
#SBATCH --partition=gpu_mig
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=9
#SBATCH --mem=32G
#SBATCH --time=00:15:00
#SBATCH --output=logs/%x-%j.out

set -euo pipefail

PROJECT_DIR="${PROJECT_DIR:-$HOME/master-thesis}"
VENV_DIR="${VENV_DIR:-$HOME/.venvs/master-thesis-transformers}"
SCRATCH_BASE="${SCRATCH_BASE:-/scratch-shared/$USER/master-thesis}"

mkdir -p "$PROJECT_DIR/logs" "$SCRATCH_BASE/hf_cache" "$SCRATCH_BASE/outputs"

module purge
module load 2025
module load Anaconda3/2025.06-1

source "$VENV_DIR/bin/activate"

export HF_HOME="$SCRATCH_BASE/hf_cache"
export HF_HUB_CACHE="$SCRATCH_BASE/hf_cache/hub"
export TRANSFORMERS_CACHE="$SCRATCH_BASE/hf_cache/transformers"
export TOKENIZERS_PARALLELISM=false

cd "$PROJECT_DIR"

srun python - <<'PY'
import os
import torch

print("Host:", os.uname().nodename)
print("Torch:", torch.__version__)
print("Torch CUDA:", torch.version.cuda)
print("CUDA available:", torch.cuda.is_available())
if torch.cuda.is_available():
    print("GPU:", torch.cuda.get_device_name(0))
    print("GPU memory total GB:", round(torch.cuda.get_device_properties(0).total_memory / 1024**3, 2))
PY

